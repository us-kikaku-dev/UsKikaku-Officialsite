# microCMS（メインコンテンツ：ニュース・ブログ・記事等）
VITE_MICROCMS_SERVICE_DOMAIN=YOUR_DOMAIN
VITE_MICROCMS_API_KEY=YOUR_API_KEY

# Capital Voice Japan（irmedia）
VITE_CAPITAL_VOICE_SERVICE_DOMAIN=irmedia
VITE_CAPITAL_VOICE_API_KEY=YOUR_API_KEY

# EmailJS（お問い合わせフォーム送信）
# 未設定の場合、フォーム送信時にエラー（送信不可）になります
VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY

# reCAPTCHA v2（お問い合わせフォーム認証）
# 未設定の場合、reCAPTCHAウィジェットは表示されず送信ボタンが無効化されます
VITE_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
